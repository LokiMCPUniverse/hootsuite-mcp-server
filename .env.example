# Hootsuite API Configuration

# Option 1: Use OAuth Access Token (recommended)
HOOTSUITE_ACCESS_TOKEN=your_access_token_here

# Option 2: Use API Key and Secret
# HOOTSUITE_API_KEY=your_api_key_here
# HOOTSUITE_API_SECRET=your_api_secret_here

# Optional: Refresh Token for OAuth
# HOOTSUITE_REFRESH_TOKEN=your_refresh_token_here

# API Configuration (optional - defaults shown)
# HOOTSUITE_API_BASE_URL=https://platform.hootsuite.com/v1

# Rate Limiting (optional - defaults shown)
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_WINDOW=60

# Retry Configuration (optional - defaults shown)
# MAX_RETRIES=3
# RETRY_DELAY=1.0

# Request Timeout (optional - defaults shown)
# REQUEST_TIMEOUT=30
